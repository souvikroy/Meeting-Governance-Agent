# Copy to .env and fill in. Never commit .env.

# --- LLM (all generative calls go through OpenRouter) ---
OPENROUTER_API_KEY=
# Strong reasoning model; swap freely (e.g. anthropic/claude-3.7-sonnet, openai/gpt-4o, google/gemini-2.5-pro)
OPENROUTER_MODEL=openai/gpt-4o

# --- STT (real speech-to-text) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# --- TTS (scenario audio generation) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Optional overrides ---
EMBED_MODEL=openai/text-embedding-3-small   # embeddings via OpenRouter; vectors stored locally
WINDOW_SIZE=4
CONFIDENCE_THRESHOLD=0.55
